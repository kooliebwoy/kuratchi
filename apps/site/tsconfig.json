{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "./worker-configuration.d.ts"
    ]
  },
  "include": [
    "src/**/*.ts",
    "kuratchi.config.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
