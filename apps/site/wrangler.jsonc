{
  "name": "site",
  "main": ".kuratchi/worker.js",
  "compatibility_date": "2026-03-06",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
      {
        "pattern": "kuratchi.dev",
        "custom_domain": true
      }
    ],
    "placement": {
      "mode": "smart"
    },
    "observability": {
      "enabled": true
    }
}
