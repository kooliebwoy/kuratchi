{
  "name": "kuratchi-syntax",
  "displayName": "KuratchiJS",
  "description": "Syntax highlighting for KuratchiJS .kuratchi route files: expressions, native JS control flow, attribute binding, and embedded <script>/<style> blocks.",
  "version": "0.3.0",
  "publisher": "kuratchi",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "scripts": {
    "package": "vsce package --no-dependencies"
  },
  "contributes": {
    "languages": [
      {
        "id": "kuratchi",
        "aliases": [
          "Kuratchi",
          "kuratchi"
        ],
        "extensions": [
          ".kuratchi"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/kuratchi-light.svg",
          "dark": "./icons/kuratchi-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "kuratchi",
        "scopeName": "text.html.kuratchi",
        "path": "./syntaxes/kuratchi.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.javascript": "javascript",
          "meta.embedded.block.typescript": "typescript",
          "meta.embedded.block.css": "css",
          "source.js": "javascript",
          "source.ts": "typescript",
          "source.css": "css"
        }
      }
    ]
  }
}


