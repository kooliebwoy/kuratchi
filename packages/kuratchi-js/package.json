{
    "name": "@kuratchi/js",
    "version": "0.0.30",
    "description": "A thin, Cloudflare Workers-native web framework with Svelte-inspired syntax",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "check": "tsc -p tsconfig.build.json --noEmit",
        "test": "bun test",
        "test:watch": "bun test --watch",
        "prepublishOnly": "npm run build"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./runtime/context.js": {
            "types": "./dist/runtime/context.d.ts",
            "import": "./dist/runtime/context.js"
        },
        "./runtime/request.js": {
            "types": "./dist/runtime/request.d.ts",
            "import": "./dist/runtime/request.js"
        },
        "./runtime/navigation.js": {
            "types": "./dist/runtime/navigation.d.ts",
            "import": "./dist/runtime/navigation.js"
        },
        "./runtime/do.js": {
            "types": "./dist/runtime/do.d.ts",
            "import": "./dist/runtime/do.js"
        },
        "./runtime/schema.js": {
            "types": "./dist/runtime/schema.d.ts",
            "import": "./dist/runtime/schema.js"
        },
        "./runtime/router.js": {
            "types": "./dist/runtime/router.d.ts",
            "import": "./dist/runtime/router.js"
        },
        "./runtime/types.js": {
            "types": "./dist/runtime/types.d.ts",
            "import": "./dist/runtime/types.js"
        },
        "./runtime/environment.js": {
            "types": "./dist/runtime/environment.d.ts",
            "import": "./dist/runtime/environment.js"
        },
        "./runtime/assets.js": {
            "types": "./dist/runtime/assets.d.ts",
            "import": "./dist/runtime/assets.js"
        },
        "./runtime/workflow.js": {
            "types": "./dist/runtime/workflow.d.ts",
            "import": "./dist/runtime/workflow.js"
        },
        "./runtime/stream.js": {
            "types": "./dist/runtime/stream.d.ts",
            "import": "./dist/runtime/stream.js"
        },
        "./runtime/security.js": {
            "types": "./dist/runtime/security.d.ts",
            "import": "./dist/runtime/security.js"
        },
        "./request": {
            "types": "./dist/runtime/request.d.ts",
            "import": "./dist/runtime/request.js"
        },
        "./navigation": {
            "types": "./dist/runtime/navigation.d.ts",
            "import": "./dist/runtime/navigation.js"
        },
        "./context": {
            "types": "./dist/runtime/context.d.ts",
            "import": "./dist/runtime/context.js"
        },
        "./schema": {
            "types": "./dist/runtime/schema.d.ts",
            "import": "./dist/runtime/schema.js"
        },
        "./workflow": {
            "types": "./dist/runtime/workflow.d.ts",
            "import": "./dist/runtime/workflow.js"
        },
        "./security": {
            "types": "./dist/runtime/security.d.ts",
            "import": "./dist/runtime/security.js"
        },
        "./compiler": {
            "types": "./dist/compiler/index.d.ts",
            "import": "./dist/compiler/index.js"
        },
        "./environment": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "engines": {
        "node": ">=18"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "esbuild": "^0.25.0",
        "typescript": "^5.8.0"
    },
    "peerDependencies": {
        "@tailwindcss/postcss": "^4.0.0",
        "lightningcss": "^1.0.0",
        "postcss": "^8.0.0",
        "tailwindcss": "^4.0.0"
    },
    "peerDependenciesMeta": {
        "@tailwindcss/postcss": {
            "optional": true
        },
        "lightningcss": {
            "optional": true
        },
        "postcss": {
            "optional": true
        },
        "tailwindcss": {
            "optional": true
        }
    },
    "devDependencies": {
        "@cloudflare/workers-types": "^4.20260223.0",
        "@types/node": "^24.4.0"
    }
}
